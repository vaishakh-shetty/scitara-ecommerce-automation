{
  "name": "e-commerce-dummy-cases",
  "version": "1.0.0",
  "description": "E-Commerce UI with full automation coverage — API, E2E (Playwright + POM), Load (k6)",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"json-server --watch db.json --port 3001\" \"vite\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "server": "json-server --watch db.json --port 3001",
    "test:all": "playwright test --reporter=html",
    "test:api": "playwright test --grep @api --reporter=html",
    "test:e2e": "playwright test tests/specs --reporter=html",
    "test:listing": "playwright test --grep @listing --reporter=html",
    "test:details": "playwright test --grep @details --reporter=html",
    "test:cart": "playwright test --grep @cart --reporter=html",
    "test:checkout": "playwright test --grep @checkout --reporter=html",
    "test:e2e-flows": "playwright test --grep @e2e --reporter=html",
    "test:cross-layer": "playwright test --grep @cross-layer --reporter=html",
    "test:negative": "playwright test --grep @negative --reporter=html",
    "test:headed": "playwright test tests/specs --headed",
    "test:chromium": "playwright test --project=chromium --reporter=html",
    "test:firefox": "playwright test --project=firefox --reporter=html",
    "test:webkit": "playwright test --project=webkit --reporter=html",
    "load:smoke": "k6 run load/smoke.test.js",
    "load:load": "k6 run load/load.test.js",
    "load:stress": "k6 run load/stress.test.js",
    "load:spike": "k6 run load/spike.test.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@types/node": "^20.12.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "json-server": "^0.17.4",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}
